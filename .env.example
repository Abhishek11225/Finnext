# App
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Public stock quote key used by client-side widgets. Prefer FINNHUB_API_KEY
# for server routes when possible.
NEXT_PUBLIC_FINNHUB_API_KEY=your_public_finnhub_key
FINNHUB_API_KEY=your_server_finnhub_key
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE?retryWrites=true&w=majority

# Better Auth
BETTER_AUTH_SECRET=replace_with_a_32_plus_character_random_secret
BETTER_AUTH_URL=http://localhost:3000

# Email
NODEMAILER_EMAIL=your_email@example.com
NODEMAILER_PASSWORD=your_app_password

# AI providers
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
NVIDIA_API_KEY=your_nvidia_api_key

# Cron route protection
CRON_SECRET=replace_with_a_long_random_secret

# Optional services
TRADING_AGENTS_URL=https://your-trading-agents-service.example.com
ACADEMY_CLOUDINARY_VIDEO_BASE_URL=https://res.cloudinary.com/YOUR_CLOUD/video/upload
NEXT_PUBLIC_ACADEMY_CLOUDINARY_VIDEO_BASE_URL=https://res.cloudinary.com/YOUR_CLOUD/video/upload
