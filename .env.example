# Next.js Environment Configuration
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Finnhub API configuration for stock data
FINNHUB_API_KEY=your_finnhub_api_key_here
NEXT_PUBLIC_FINNHUB_API_KEY=your_finnhub_api_key_here
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# MongoDB Database Connection String
MONGODB_URI=your_mongodb_connection_string_here

# Better Auth Configuration
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:3000

# Nodemailer Configuration for Email delivery
NODEMAILER_EMAIL=your_email_address_here
NODEMAILER_PASSWORD=your_email_password_or_app_password_here

# NVIDIA NIM API configuration for AI Analysis
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-nano-30b-a3b

# Groq API configuration for Academy AI Assistant
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Cron Security Secret for automated background jobs
CRON_SECRET=your_cron_secret_here

# Cloudinary Configuration for Academy and Portfolio uploads (Optional/New)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
ACADEMY_CLOUDINARY_VIDEO_BASE_URL=https://res.cloudinary.com/dz4zyjg3s/video/upload
NEXT_PUBLIC_ACADEMY_CLOUDINARY_VIDEO_BASE_URL=https://res.cloudinary.com/dz4zyjg3s/video/upload

# Optional external trading-agents microservice
TRADING_AGENTS_URL=http://localhost:8000
