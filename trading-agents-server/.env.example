# TradingAgents Server — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The server reads these from the parent project's .env automatically
# via the start.bat script, but you can also set them here.

# NVIDIA NIM (required)
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-nano-30b-a3b

# FinnHub (required for real market data)
FINNHUB_API_KEY=your-finnhub-key-here

# Server config (optional)
PORT=8000
